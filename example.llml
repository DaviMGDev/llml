// this gonna be a dialect of my "lingua" language, the name of the dialect is "llml" which stands for llm language.
// all the original features are the same of lingua, so I will only explain what is new in this dialect.

// ~= operator 

package llml 

import "agents" 

agents.setup() // this will setup everythin that is needed plus will run alias and macros directly in this "scope", so we can use "promt()" instead of "agents.prompt()"
// events still use explicit namespaces though.

print("hi" ~= "greeting") // this will be evaluated to true because "hi" is a greeting 
print("hi" ~= "hello") // this will be evaluated to true because "hi" is semantically similar to "hello" 
print("hi" ~= string) // this kind of comparison will not use a llm 
print(10 ~= 10) // this will also not use a llm because it is a number comparison
print(10 ~= 10.1) // this will also not use a llm because it is a number comparison. will be true if the numbers are close enough to each other, false otherwise.
print({"name": "John", "age": 30} ~= "adult") // evaluated with llm. probably will be true. "probably" because llm's are probabilistic models.

x: string = "john"

if x ~= "male" {  
    print("${x} is a male")
} else {
    print("${x} is not a male")
}

// the ~= operator can also be used to compare objects with each other, for example: 

class Dog {
    name: string
    age: integer
    breed: string

    function init(name: string, age: int, breed: string) {
        this.name = name
        this.age = age
        this.breed = breed
    }
}

dog: Dog = Dog("Buddy", 3, "Golden Retriever") 

print(dog ~= "a dog named buddy") // this will be evaluated to true because the dog object is semantically similar to the string "a dog named buddy"
print(dog ~= "a cat") // this will be evaluated to false because the dog object is not semantically similar to the string "a cat"

if dog ~= "a golden retriever" {
    print("${dog.name} is a golden retriever")
} else {
    print("${dog.name} is not a golden retriever")
}

// you already got the idea of how the operator works.

// since our "compiler" is bundled with an agent, and an agent is basically a llm with tool calling, we can add tools to our main agent
// function -> tool:
@tool(description="Get the weather of a location")
function get_weather(location: string): string {
    // this function will be used to get the weather of a location
    // the implementation of this function is not important for this example, so we will just return a dummy value
    return "sunny"
} 

// now we can use the get_weather function in our code, and the agent will be able to call it when needed
// but you're probably wondering how we even call the agent. this is how:
print(prompt("what is the weather of New York?")) // this will call the agent, and the agent will call the get_weather function to get the weather of New York
// btw, prompt() returns the type (any, error), normally, the result is a string, but if you use strict typing, and not inference, the compiler will "force" the agent to return the type you specified, if after some retries the agent still can't return the type you specified, it will return an error.

x, e := prompt("what is 2**10?") // this will call the agent, and the agent will return 1024, probably 
chiuaua, e: Dog, error = prompt("give me a chiuaua dog") // this will call the agent, and the agent will return a chiuaua dog object, at least it will try.

// btw, prompt is interpreted by our main agent, however, you can create subagents

agent Planner { // agent is basically a class, but auto inherit from the base Agent class, which is the main agent.
    // standard properties of an agent: 
    system: string = "You are a planner agent, you will be given a task, and you will plan how to do it, and return the plan as a string. You can use tools if needed."
    tools: []tool = [] // none for now, but you can add tools to this agent if needed 
    model: string = "deepseek-v4-pro" // default is inherited from the main agent.
    // extra attributes that you add at will, for example: 
    data: any = "you"

    // you can add normal functions, which will not be accessible for the llm as tool:
    function do_something() {
        print("doing something")
    }

    // but you can define internal tools:
    @tool(description="Plan a task")
    function plan_task(task: string): string {
        // this function will be used to plan a task
        // the implementation of this function is not important for this example, so we will just return a dummy value
        return "1. Do this\n2. Do that\n3. Done"
    }
}

// to use the subagent: 
print(Planner.prompt("plan a task to build a house")) // this will call the Planner agent, and the Planner agent will call the plan_task function to plan the task of building a house

// by default, agents can only call tools.
// later I plan on making a standard library with default tools, support for agent skills, support explicit to calling other agents, and more. 

// prompt() function are blocking. you can use coroutines to make them non-blocking, for example: 
ch: channel[string] = channel[string]() // create a channel to communicate between coroutines
run function(ch: channel[string]) { // run a coroutine 
    result, err := prompt("what is the weather of New York?") // this will call the agent, and the agent will call the get_weather function to get the weather of New York 
    if err != nil {
        // handle the error. it will not send to the same channel that we expect a result though... 
    } else {
        ch <- result // send the result to the channel
    }
}(ch)

// btw, our event system also works here:

on agents.Planner.before_user_prompt := ev {
    print("Planner agent is about to receive a prompt: ${ev.prompt}")
}

on agents.before_user_prompt := ev {
    print("Main agent is about to receive a prompt: ${ev.prompt}")
}

result, err := prompt("what is the weather of New York?") // this will call the main agent, and the main agent will call the get_weather function to get the weather of New York 

// this will also trigger the event handlers we defined above, and print the following: 
// Main agent is about to receive a prompt: what is the weather of New York? 

// this is a demo of a set of this dialect's features. 
// obviously there are more events, there are more default tools, default subagents, skills, mcp, acp, a2a, 
// might use embeddings for the ~= operator.
// btw, this is not even the code explaining how this were implemented nor is a full specification of the dialect, this is just a demo of the features. 
