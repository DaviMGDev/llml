// LLML - LLM Language
// A toy language that merges deterministic programming with LLMs.


// ============================================================
// 1. Semantic comparison with ~=
// ============================================================

// The ~= operator compares two objects/values semantically and returns a boolean.

// --- Value ~= type ---
if ("hi" ~= "greeting") {
    print("hi is a greeting")
} else {
    print("hi is not a greeting")
}

// --- Value ~= value ---
// Deterministic comparisons are resolved without calling an LLM.
// 20 ~= 20         -> true
// 20 ~= 20.01      -> true  (similar numbers)

// --- Object ~= type ---
type Natural struct {
    value int
}

Natural{value: 20} ~= int           // true
Natural{value: 20} ~= "number"      // true
Natural{value: 20} ~= "can be a age" // true

// --- Object ~= object ---
// <object> ~= <object> is also supported.


// ============================================================
// 2. Prompting the agent
// ============================================================

// Default prompt result is a string.
response := prompt("what is the meaning of life?")

// To get a specific type, wrap it in Response[T].
var value Response[int] = prompt("what is 2 + 2?")


// ============================================================
// 3. Tools for the LLM
// ============================================================

// Use the @tool decorator to expose a function to the LLM.
@tool("this is a tool to get the weather of a city")
func getWeather(city string) string {
    return "sunny"
}

// The LLM can invoke the tool automatically when needed.
print(prompt("what is the weather of New York?"))


// ============================================================
// 4. Subagents
// ============================================================

agent Planner {
    system := "You are a planner agent. You can plan things for the user."

    // Subagents must explicitly declare the tools they can use.
    tools := {getWeather}

    // Internal attributes are only accessible via internal tools or methods.
    attribute := "value"

    // Methods are not exposed to the LLM; tools can call them internally.
    func method() string {
        return this.attribute
    }

    @tool("this is a tool to get the attribute of the agent")
    func getAttribute() string {
        return method()
        // return this.attribute would also work
    }
}

// Subagents are not automatically available to the LLM unless exposed through a tool.
// You can call a subagent directly from the main program.
Planner.prompt("what is the weather of New York?")
Planner.prompt("get your internal attribute")

// Methods belong to the agent object and are callable from the main program.
print(Planner.method()) // prints: value


// ============================================================
// 5. Event system
// ============================================================

// Define, emit and listen to events.
event Event {
    id int
}

emit Event {
    id: 1
}

on Event {
    print("event received with id: " + Event.id)
}

// Events can also be declared inside classes. They are scoped to their owner.
class Person {
    name string

    func greet() {
        emit Greet {
            who: this.name
        }
    }

    event Greet {
        who string
    }

    on Greet {
        print("greet event received from: " + Greet.who)
    }
}

// Emit and listen using the class-qualified event name.
emit Person.Greet {
    who: "Alice"
}

on Person.Greet {
    print("greet event received from: " + Person.Greet.who)
}


// ============================================================
// 6. Built-in agent events
// ============================================================

// Every agent (including the main agent and subagents) has built-in events.

// Main agent events can be listened to directly.
on UserInput {
    print("user input received: " + UserInput.input)
}

on AgentResponse {
    print("agent response received: " + AgentResponse.response)
}

// Subagent events are accessed through the agent name.
on Planner.UserInput {
    print("user input received: " + Planner.UserInput.input)
}

on Planner.AgentResponse {
    print("agent response received: " + Planner.AgentResponse.response)
}


// ============================================================
// Notes
// ============================================================

// This is a toy language; many implementation details are intentionally omitted.
// The final syntax may differ, especially because LLML is planned to be
// transpiled to Go to leverage Go's concurrency and performance.
