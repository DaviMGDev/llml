// ── TIPS ──────────────────────────────────────────────────────────────────────

cleanup_temp_files() .tip(remove all .tmp files older than 7 days in /tmp, use find -mtime)
migrate_database() .tip(this is a destructive operation — ask the user for confirmation)
return .tip(stop the pipeline here)

// ── JSON DATA ─────────────────────────────────────────────────────────────────

config = {
    "services": ["api", "worker", "scheduler"],
    "health_endpoints": {
        "api": "http://localhost:3000/health"
    },
    "alert_email": "ops@example.com"
}

for service in config.services {
    endpoint = config.health_endpoints[service]
    curl -f -s -o /dev/null $endpoint .tip(check if the endpoint returns HTTP 200)

    if $result ~= "service unhealthy" {
        send_email(
            to: config.alert_email,
            subject: "[ALERT] " + service + " is down",
            body: "Health check failed"
        ) .tip(use curl or mail command to actually send the email)
    }
}
