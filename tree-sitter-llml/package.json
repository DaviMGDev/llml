{
  "name": "tree-sitter-llml",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for LLML (LLM Language)",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/tree-sitter-llml"
  },
  "keywords": [
    "tree-sitter",
    "parser",
    "llml",
    "llm-language"
  ],
  "files": [
    "grammar.js",
    "binding.gyp",
    "bindings/**/*.js",
    "bindings/**/*.ts",
    "src/**/*",
    "queries/**/*"
  ],
  "dependencies": {
    "node-addon-api": "^7.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.23.0",
    "prebuildify": "^6.0.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "tree-sitter": [
    {
      "scope": "source.llml",
      "injection-regex": "^llml$"
    }
  ]
}
