; ── Folding ──────────────────────────────────────────────────────────

(comment) @fold

(block) @fold

(function_definition
  body: (block) @fold)

(class_definition) @fold

(method_definition
  body: (block) @fold)

(if_statement
  body: (block) @fold)

(for_statement
  body: (block) @fold)

(when_statement
  body: (block) @fold)

(step_definition
  body: (block) @fold)

(confirm_block
  body: (block) @fold)
